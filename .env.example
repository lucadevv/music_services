# Application
PROJECT_NAME=YouTube Music Service
PROJECT_VERSION=1.0.0

API_VERSION=v1
API_PREFIX=/api/v1

DEBUG=false
LOG_level=INFO

cors_origins=*
cors_allow_credentials=true
cors_allow_methods=*
cors_allow_headers=*

# Server
host=0.0.0.0
port=8000
workers=4

# Redis
redis_host=redis
redis_port=6379
redis_db=0
redis_password=

# Browser Authentication
browser_accounts_dir=/app/browser

# Admin
admin_secret_key=your-secret-admin-key

