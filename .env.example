# Application
PROJECT_name=YouTube Music Service
project_version=1.0.0

API_VERSION=v1
API_PREFIX=/api/v1

DEBUG=false
LOG_level=INFO

# Server
host=0.0.0.0
port=8000
workers=4

# CORS
cors_origins=*
cors_allow_credentials=true
cors_allow_methods=*
cors_allow_headers=*

# PostgreSQL
postgres_host=postgres
postgres_port=5432
postgres_user=music_user
postgres_password=music_password
postgres_db=music_db

# Admin
admin_secret_key=change-me-in-production-use-strong-key

rate_limit_enabled=true
rate_limit_per_minute=60
rate_limit_per_hour=1000

# Redis (for YouTube Music cache)
redis_host=redis
redis_port=6379
redis_db=0
redis_password=

# Browser Authentication
browser_accounts_dir=/app/browser

# Rate Limiting
rate_limit_enabled=true
rate_limit_per_minute=60
rate_limit_per_hour=1000

# Logging
log_level=INFO

# HTTP Client
http_timeout=30
http_max_connections=100
http_max_keepalive_connections=20

